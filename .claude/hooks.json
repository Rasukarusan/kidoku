{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "bash scripts/sandbox-setup.sh 2>&1 | tail -30",
        "timeout": 300
      }
    ],
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash scripts/hooks/pre-tool-use.sh \"$TOOL_NAME\" \"$TOOL_INPUT\"",
        "timeout": 10
      }
    ]
  }
}
