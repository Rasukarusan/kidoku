generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider     = "mysql"
  url          = env("DATABASE_URL")
  relationMode = "prisma"
}

model sheets {
  id      Int       @id @default(autoincrement()) @db.UnsignedInt
  userId  String    @map("user_id")
  name    String    @db.VarChar(120)
  order   Int?      @default(1)
  created DateTime? @default(now()) @db.DateTime(0)
  updated DateTime? @default(now()) @db.DateTime(0)
  user    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  books   books[]

  @@unique([userId, name], map: "uniq_user_id_name")
}

model books {
  id               Int             @id @default(autoincrement()) @db.UnsignedInt
  userId           String          @map("user_id")
  sheetId          Int             @map("sheet_id")
  title            String          @db.VarChar(120)
  author           String          @db.VarChar(120)
  category         String          @db.VarChar(120)
  image            String          @db.VarChar(255)
  impression       String          @db.VarChar(5)
  memo             String          @db.MediumText
  isPublicMemo     Boolean         @default(false) @map("is_public_memo")
  isPurchasable    Boolean         @default(false) @map("is_purchasable")
  price            String?         @db.VarChar(40)
  media            String?         @db.VarChar(20)
  finished         DateTime?       @db.DateTime(0)
  created          DateTime        @default(now()) @db.DateTime(0)
  updated          DateTime        @default(now()) @db.DateTime(0)
  sheet            sheets          @relation(fields: [sheetId], references: [id], onDelete: Cascade)
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  yearly_top_books YearlyTopBook[]
  likes            Like[]
  purchases        Purchase[]
  bookComments     BookComment[]
  quotes           Quote[]
  bookTags         BookTag[]
  reReadings       ReReading[]
  bookRatings      BookRating[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id               String           @id @default(cuid())
  name             String?          @unique(map: "uniq_name")
  email            String?          @unique
  emailVerified    DateTime?        @map("email_verified")
  image            String?
  admin            Boolean          @default(false)
  suiAddress       String?          @map("sui_address") @db.VarChar(80)
  accounts         Account[]
  sessions         Session[]
  sheets           sheets[]
  yearly_top_books YearlyTopBook[]
  books            books[]
  AiSummaries      AiSummaries[]
  template_books   template_books[]
  following          Follow[]       @relation("following")
  followers          Follow[]       @relation("followers")
  likes              Like[]
  notifications      Notification[] @relation("notificationUser")
  actorNotifications Notification[] @relation("notificationActor")
  purchases          Purchase[]
  bookComments       BookComment[]
  memoTemplates      MemoTemplate[]
  quotes             Quote[]
  tags               Tag[]
  reReadings         ReReading[]
  ratingAxes         RatingAxis[]
  authorFollows      AuthorFollow[]
  personalAccessTokens PersonalAccessToken[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

model YearlyTopBook {
  id      Int      @id @default(autoincrement()) @db.UnsignedInt
  userId  String   @map("user_id")
  bookId  Int      @map("book_id")
  order   Int      @default(1)
  year    String   @db.VarChar(120)
  created DateTime @default(now()) @db.DateTime(0)
  updated DateTime @default(now()) @db.DateTime(0)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book    books    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, order, year], map: "uniq_user_order_year")
  @@map("yearly_top_books")
}

model AiSummaries {
  id       Int       @id @default(autoincrement()) @db.UnsignedInt
  userId   String    @map("user_id")
  sheetId  Int @map("sheet_id")
  analysis Json
  token    Int
  created  DateTime? @default(now()) @db.DateTime(0)
  updated  DateTime? @default(now()) @db.DateTime(0)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("ai_summaries")
}

model Follow {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  followerId  String   @map("follower_id")
  followingId String   @map("following_id")
  created     DateTime @default(now()) @db.DateTime(0)
  follower    User     @relation("following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId], map: "uniq_follower_following")
  @@index([followingId])
  @@map("follows")
}

model Like {
  id          Int      @id @default(autoincrement()) @db.UnsignedInt
  userId      String?  @map("user_id")
  anonymousId String?  @map("anonymous_id") @db.VarChar(64)
  bookId      Int      @map("book_id")
  created     DateTime @default(now()) @db.DateTime(0)
  user        User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  book        books    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId], map: "uniq_user_book")
  @@unique([anonymousId, bookId], map: "uniq_anon_book")
  @@index([bookId])
  @@map("likes")
}

model Purchase {
  id               Int      @id @default(autoincrement()) @db.UnsignedInt
  userId           String   @map("user_id")
  bookId           Int      @map("book_id")
  txDigest         String   @unique @map("tx_digest") @db.VarChar(120)
  network          String   @default("testnet") @db.VarChar(20)
  amount           String   @db.VarChar(40)
  senderAddress    String   @map("sender_address") @db.VarChar(80)
  recipientAddress String   @map("recipient_address") @db.VarChar(80)
  created          DateTime @default(now()) @db.DateTime(0)
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book             books    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId], map: "uniq_user_book_purchase")
  @@index([bookId])
  @@map("purchases")
}

model Notification {
  id               Int      @id @default(autoincrement()) @db.UnsignedInt
  userId           String   @map("user_id")
  actorId          String?  @map("actor_id")
  actorAnonymousId String?  @map("actor_anonymous_id") @db.VarChar(64)
  type             String   @db.VarChar(20)
  bookId           Int?     @map("book_id")
  read             Boolean  @default(false)
  created          DateTime @default(now()) @db.DateTime(0)
  user             User     @relation("notificationUser", fields: [userId], references: [id], onDelete: Cascade)
  actor            User?    @relation("notificationActor", fields: [actorId], references: [id], onDelete: Cascade)

  @@unique([userId, actorId, type, bookId], map: "uniq_user_actor_type_book")
  @@index([userId])
  @@index([actorId])
  @@map("notifications")
}

model template_books {
  id             Int      @id @default(autoincrement()) @db.UnsignedInt
  userId         String   @map("user_id")
  name           String   @db.VarChar(120)
  title          String   @db.VarChar(120)
  author         String   @db.VarChar(120)
  category       String   @db.VarChar(120)
  image          String   @db.VarChar(255)
  memo           String   @db.MediumText
  isPublicMemo   Boolean  @default(false) @map("is_public_memo")
  created        DateTime @default(now()) @db.DateTime(0)
  updated        DateTime @default(now()) @db.DateTime(0)
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model PersonalAccessToken {
  id         Int       @id @default(autoincrement()) @db.UnsignedInt
  userId     String    @map("user_id")
  name       String    @db.VarChar(60)
  tokenHash  String    @unique @map("token_hash") @db.VarChar(64)
  lastUsedAt DateTime? @map("last_used_at") @db.DateTime(0)
  created    DateTime  @default(now()) @db.DateTime(0)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("personal_access_tokens")
}

model AuthorFollow {
  id         Int      @id @default(autoincrement()) @db.UnsignedInt
  userId     String   @map("user_id")
  authorName String   @map("author_name") @db.VarChar(120)
  created    DateTime @default(now()) @db.DateTime(0)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, authorName], map: "uniq_user_author")
  @@map("author_follows")
}

model RatingAxis {
  id      Int          @id @default(autoincrement()) @db.UnsignedInt
  userId  String       @map("user_id")
  name    String       @db.VarChar(60)
  order   Int          @default(1)
  created DateTime     @default(now()) @db.DateTime(0)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  ratings BookRating[]

  @@unique([userId, name], map: "uniq_user_axis_name")
  @@map("rating_axes")
}

model BookRating {
  id      Int        @id @default(autoincrement()) @db.UnsignedInt
  bookId  Int        @map("book_id")
  axisId  Int        @map("axis_id")
  value   Int
  created DateTime   @default(now()) @db.DateTime(0)
  updated DateTime   @default(now()) @db.DateTime(0)
  book    books      @relation(fields: [bookId], references: [id], onDelete: Cascade)
  axis    RatingAxis @relation(fields: [axisId], references: [id], onDelete: Cascade)

  @@unique([bookId, axisId], map: "uniq_book_axis")
  @@index([axisId])
  @@map("book_ratings")
}

model ReReading {
  id       Int      @id @default(autoincrement()) @db.UnsignedInt
  userId   String   @map("user_id")
  bookId   Int      @map("book_id")
  finished DateTime @db.DateTime(0)
  memo     String?  @db.MediumText
  created  DateTime @default(now()) @db.DateTime(0)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book     books    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookId])
  @@map("re_readings")
}

model Tag {
  id       Int       @id @default(autoincrement()) @db.UnsignedInt
  userId   String    @map("user_id")
  name     String    @db.VarChar(60)
  created  DateTime  @default(now()) @db.DateTime(0)
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookTags BookTag[]

  @@unique([userId, name], map: "uniq_user_tag_name")
  @@map("tags")
}

model BookTag {
  id      Int      @id @default(autoincrement()) @db.UnsignedInt
  bookId  Int      @map("book_id")
  tagId   Int      @map("tag_id")
  created DateTime @default(now()) @db.DateTime(0)
  book    books    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag     Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([bookId, tagId], map: "uniq_book_tag")
  @@index([tagId])
  @@map("book_tags")
}

model Quote {
  id      Int      @id @default(autoincrement()) @db.UnsignedInt
  userId  String   @map("user_id")
  bookId  Int      @map("book_id")
  page    Int?
  text    String   @db.Text
  comment String?  @db.Text
  created DateTime @default(now()) @db.DateTime(0)
  updated DateTime @default(now()) @db.DateTime(0)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  book    books    @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([bookId])
  @@map("quotes")
}

model MemoTemplate {
  id        Int      @id @default(autoincrement()) @db.UnsignedInt
  userId    String   @map("user_id")
  name      String   @db.VarChar(120)
  content   String   @db.MediumText
  isDefault Boolean  @default(false) @map("is_default")
  created   DateTime @default(now()) @db.DateTime(0)
  updated   DateTime @default(now()) @db.DateTime(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("memo_templates")
}

model BookComment {
  id      Int      @id @default(autoincrement()) @db.UnsignedInt
  bookId  Int      @map("book_id")
  userId  String   @map("user_id")
  content String   @db.Text
  created DateTime @default(now()) @db.DateTime(0)
  updated DateTime @default(now()) @db.DateTime(0)
  book    books    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([bookId])
  @@index([userId])
  @@map("book_comments")
}
